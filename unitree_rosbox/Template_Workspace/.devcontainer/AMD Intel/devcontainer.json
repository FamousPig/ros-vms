{
  "name": "Unitree-ROS2 development environment (AMD/Intel)",
  "remoteUser": "rosdev",
  "build": {
      "dockerfile": "../Dockerfile",
      "args": {
          "USERNAME": "rosdev",
          "GID": "1000",
          "UID": "1000"
      }
  },
  "customizations": {
      "vscode": {
          "extensions": [
              "ms-vscode.cpptools-extension-pack", 
              "ranch-hand-robotics.rde-ros-2",
              "smilerobotics.urdf",
              "redhat.vscode-xml",
              "tamasfe.even-better-toml",
              "yzhang.markdown-all-in-one"
          ],
          "settings": {
              "files.associations": {
                  "*.rviz": "yaml",
                  "*.srdf": "xml",
                  "*.urdf": "xml",
                  "*.xacro": "xml"
              }
          }
      }
  },
 // "hostRequirements": {
 //   "gpu": {"optional"}
 //},
  "workspaceFolder": "/home/rosdev/ros2_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/rosdev/ros2_ws,type=bind",
   "containerEnv": {
    },
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
      ],
  "runArgs": [
      "--net=host",
      "--device=/dev/dri",
      "--env=DISPLAY"
],
"features": {
	//"ghcr.io/devcontainer-config/features/dot-config:4": {}
    }
}