{
  "name": "Unitree-ROS2 development environment",
  "remoteUser": "rosdev",
  "build": {
      "dockerfile": "Dockerfile",
      "args": {
          "USERNAME": "rosdev",
          "GID": "1000",
          "UID": "1000"
      }
  },
  "customizations": {
      "vscode": {
          "extensions": [
            // TODO clean this up
              "ms-python.python",
              "charliermarsh.ruff",
              "ms-vscode.cpptools-extension-pack",
              "ms-iot.vscode-ros",
              "smilerobotics.urdf",
              "redhat.vscode-xml",
              "tamasfe.even-better-toml",
              "timonwong.shellcheck",
              "yzhang.markdown-all-in-one",
          ],
          "settings": {
              "files.associations": {
                  "*.rviz": "yaml",
                  "*.srdf": "xml",
                  "*.urdf": "xml",
                  "*.xacro": "xml"
              }
          }
      }
  },
 // "hostRequirements": {
 //   "gpu": {"optional"}
 //},
  "workspaceFolder": "/home/rosdev/ros2_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/rosdev/ros2_ws/src,type=bind",
   "containerEnv": {
        "DISPLAY": "unix:0"
    },
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
      ],
  "runArgs": [
      "--net=host",
      "--runtime=nvidia",
      "--gpus=all"
],
"features": {
	//"ghcr.io/devcontainer-config/features/dot-config:4": {}
}
}