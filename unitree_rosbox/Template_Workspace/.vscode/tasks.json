{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Simulator (Mujoco)",
            "type": "process",
            "command": "/home/rosdev/unitree_mujoco/simulate/build/unitree_mujoco",
            "args": [
                "-rg1",
                "-sscene_29dof.xml",
                "-e1"
            ],
            "problemMatcher": []
        },
        {
            "label": "glxgears",
            "type": "process",
            "command": "glxgears"
        },
        {
            "label": "colcon: build (debug)",
            "type": "shell",
            "command": [
                "source setup_local.sh;",
                "colcon build --paths example/src",
                "--symlink-install",
                "--event-handlers console_cohesion+",
                "--base-paths workspace-path",
                "--cmake-args -DCMAKE_BUILD_TYPE=Debug"
            ]
        },
        {
            "label": "colcon: clean",
            "type": "shell",
            "command": [
                "cd project-workspace;",
                "rm -rf build/ install/ log/;"
            ]
        }
    ]
}